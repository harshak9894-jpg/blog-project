<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body public-feed-body">
  <main class="public-feed-shell">
    <section class="public-feed-board">
      <header class="public-feed-header">
        <a href="/" class="public-feed-brand" aria-label="Delulu Home">
          <img src="/delulu-logo.png" alt="Delulu logo" class="public-feed-brand-mark">
          <span class="public-feed-brand-word">DELULU</span>
        </a>

        <nav class="public-feed-nav" aria-label="Primary">
          <a href="/" class="public-feed-nav-link is-active">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.1 3.7 10v10.4h5.7v-6.1h5.2v6.1h5.7V10L12 3.1Z" fill="currentColor"/></svg>
            <span>HOME</span>
          </a>
        </nav>

        <a href="/login" class="public-feed-login-btn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 11.3a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Zm0 2.6c-4.3 0-7.5 2.3-8.3 5.8a1 1 0 0 0 1 1.3h14.6a1 1 0 0 0 1-1.3c-.8-3.5-4-5.8-8.3-5.8Z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"/></svg>
          <span>Login</span>
        </a>
      </header>

      <section class="public-feed-stage">
        <% if (success.length > 0) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <% if (error.length > 0) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div class="public-feed-grid">
          <section class="public-feed-main">
            <article class="public-card public-compose-card">
              <div class="public-post-head">
                <div class="public-author-lockup">
                  <img src="/uploads/profile/default-avatar.svg" alt="Default profile" class="public-avatar public-avatar-lg">
                  <div class="public-author-copy">
                    <strong>@account_name</strong>
                  </div>
                </div>

                <div class="public-menu-wrap">
                  <button type="button"
                          class="public-icon-menu public-menu-toggle"
                          data-menu-id="guest-compose-menu"
                          aria-label="Open menu">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="5" cy="12" r="1.8" fill="currentColor"/><circle cx="12" cy="12" r="1.8" fill="currentColor"/><circle cx="19" cy="12" r="1.8" fill="currentColor"/></svg>
                  </button>
                  <div class="public-menu-card" data-menu-for="guest-compose-menu" hidden>
                    <a href="/register" class="public-menu-item text-decoration-none">Register new account</a>
                  </div>
                </div>
              </div>

              <a href="/login" class="public-compose-box text-decoration-none">
                <span>Post something...</span>
              </a>

              <div class="public-action-row">
                <div class="public-action-cluster">
                  <a href="/login" class="public-action-item is-heart text-decoration-none" title="Login to like">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20.3s-6.6-4.1-9.1-8.2C.9 8.8 2.4 4.8 6 4.5c2.1-.2 3.5.8 4.5 2.2 1-1.4 2.4-2.4 4.5-2.2 3.6.3 5.1 4.3 3.1 7.6-2.5 4.1-9.1 8.2-9.1 8.2Z" fill="currentColor"/></svg>
                    <span>Like</span>
                  </a>
                  <a href="/login" class="public-action-item text-decoration-none" title="Login to comment">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.1 11.6c0 4.7-4 8.4-9 8.4-1.2 0-2.4-.2-3.4-.7L3.4 20.7l1.4-3.5A8.1 8.1 0 0 1 2 11.6C2 6.9 6 3.2 11.1 3.2c5 0 9 3.7 9 8.4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    <span>Comment</span>
                  </a>
                  <button type="button"
                          class="public-action-item public-share-btn"
                          data-share-url="/"
                          data-share-text="See what people are posting on Delulu">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 10 14m11-11-7.1 18-3.5-7.4L3 10.2 21 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>Share</span>
                  </button>
                </div>

                <span class="public-action-divider" aria-hidden="true"></span>

                <div class="public-action-cluster">
                  <a href="/login" class="public-action-item text-decoration-none" title="Login to create a downloadable post">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v10.6m0 0 4-4M12 14.1l-4-4M4.3 19h15.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>Download</span>
                  </a>
                  <a href="/login" class="public-action-item is-save text-decoration-none" title="Login to save">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3.8h12a1 1 0 0 1 1 1v15.4l-7-3.8-7 3.8V4.8a1 1 0 0 1 1-1Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    <span>Save</span>
                  </a>
                </div>
              </div>
            </article>

            <% if (posts.length === 0) { %>
              <article class="public-card public-empty-card">
                <div class="public-empty-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M4 6.8A2.8 2.8 0 0 1 6.8 4h10.4A2.8 2.8 0 0 1 20 6.8v10.4a2.8 2.8 0 0 1-2.8 2.8H6.8A2.8 2.8 0 0 1 4 17.2V6.8Zm4.6 2.5h6.8m-6.8 4.1h6.8m-6.8 4.1h4.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </div>
                <h2>No public posts yet</h2>
                <p>Login and create the first post to start the feed with photos, videos, and discussions.</p>
                <a href="/login" class="public-primary-btn text-decoration-none">Go to login</a>
              </article>
            <% } %>

            <% posts.forEach(post => { %>
              <article class="public-card public-post-card">
                <div class="public-post-head">
                  <div class="public-author-lockup">
                    <img src="<%= post.author.profilePic || '/uploads/profile/default-avatar.svg' %>"
                         alt="Profile picture"
                         class="public-avatar public-avatar-md">
                    <div class="public-author-copy">
                      <strong>@<%= post.author.handle || post.author.username %></strong>
                      <span><%= post.relativeTime %></span>
                    </div>
                  </div>

                  <div class="public-menu-wrap">
                    <button type="button"
                            class="public-icon-menu public-menu-toggle"
                            data-menu-id="post-menu-<%= post._id %>"
                            aria-label="Open menu">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="5" cy="12" r="1.8" fill="currentColor"/><circle cx="12" cy="12" r="1.8" fill="currentColor"/><circle cx="19" cy="12" r="1.8" fill="currentColor"/></svg>
                    </button>
                    <div class="public-menu-card" data-menu-for="post-menu-<%= post._id %>" hidden>
                      <button type="button"
                              class="public-menu-item public-report-trigger"
                              data-post-id="<%= post._id %>"
                              data-post-title="<%= post.title %>">
                        Report
                      </button>
                    </div>
                  </div>
                </div>

                <% if (post.media) { %>
                  <div class="public-post-body with-media">
                    <div class="public-media-wrap">
                      <% if (post.mediaType === "image") { %>
                        <img src="<%= post.media %>" alt="Post media" class="public-post-media">
                      <% } else { %>
                        <video class="public-post-media" controls muted playsinline>
                          <source src="<%= post.media %>" type="video/mp4">
                        </video>
                      <% } %>
                    </div>
                    <div class="public-post-copy">
                      <h3><%= post.title %></h3>
                      <p><%= post.content %></p>
                    </div>
                  </div>
                <% } else { %>
                  <div class="public-post-copy public-post-copy-text">
                    <h3><%= post.title %></h3>
                    <p><%= post.content %></p>
                  </div>
                <% } %>

                <div class="public-action-row public-action-row-post">
                  <div class="public-action-cluster">
                    <a href="/login" class="public-stat-item is-heart text-decoration-none" title="Login to like">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20.3s-6.6-4.1-9.1-8.2C.9 8.8 2.4 4.8 6 4.5c2.1-.2 3.5.8 4.5 2.2 1-1.4 2.4-2.4 4.5-2.2 3.6.3 5.1 4.3 3.1 7.6-2.5 4.1-9.1 8.2-9.1 8.2Z" fill="currentColor"/></svg>
                      <span><%= post.likes.length %></span>
                    </a>
                    <a href="/login" class="public-stat-item text-decoration-none" title="Login to comment">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.1 11.6c0 4.7-4 8.4-9 8.4-1.2 0-2.4-.2-3.4-.7L3.4 20.7l1.4-3.5A8.1 8.1 0 0 1 2 11.6C2 6.9 6 3.2 11.1 3.2c5 0 9 3.7 9 8.4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                      <span><%= post.comments.length %></span>
                    </a>
                    <button type="button"
                            class="public-stat-item public-share-btn"
                            data-share-url="/post/<%= post._id %>"
                            data-share-text="<%= post.title %>">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 10 14m11-11-7.1 18-3.5-7.4L3 10.2 21 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      <span><%= Math.max(post.comments.length + post.likes.length, 1) %></span>
                    </button>
                  </div>

                  <span class="public-action-divider" aria-hidden="true"></span>

                  <div class="public-action-cluster">
                    <% if (post.media) { %>
                      <a href="<%= post.media %>" download class="public-action-item text-decoration-none">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v10.6m0 0 4-4M12 14.1l-4-4M4.3 19h15.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>Download</span>
                      </a>
                    <% } else { %>
                      <a href="/post/<%= post._id %>" class="public-action-item text-decoration-none">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v10.6m0 0 4-4M12 14.1l-4-4M4.3 19h15.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>Open</span>
                      </a>
                    <% } %>
                    <a href="/login" class="public-action-item is-save text-decoration-none" title="Login to save">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3.8h12a1 1 0 0 1 1 1v15.4l-7-3.8-7 3.8V4.8a1 1 0 0 1 1-1Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                      <span>Save</span>
                    </a>
                  </div>
                </div>
              </article>
            <% }) %>
          </section>

          <aside class="public-feed-sidebar">
            <form action="/" method="GET" class="public-side-card public-filter-card" id="public-sort-form">
              <input type="hidden" name="category" value="<%= activeCategory %>">
              <button type="button"
                      class="public-filter-toggle"
                      data-dropdown-id="public-sort-dropdown"
                      aria-expanded="false">
                <span><%= guestTabLabel %></span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6.8 9.5 5.2 5.2 5.2-5.2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>

              <div class="public-filter-list" data-dropdown-panel="public-sort-dropdown" hidden>
                <% [{ value: "latest", label: "Latest" }, { value: "old", label: "Old" }, { value: "popular", label: "Popular" }].forEach(option => { %>
                  <button type="submit"
                          name="tab"
                          value="<%= option.value %>"
                          class="public-filter-option <%= activeTab === option.value ? 'is-active is-blue' : '' %>">
                    <span><%= option.label %></span>
                    <% if (activeTab === option.value) { %>
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4 4L19 6.8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <% } %>
                  </button>
                <% }) %>
              </div>
            </form>

            <form action="/" method="GET" class="public-side-card public-filter-card public-filter-card-warm" id="public-category-form">
              <input type="hidden" name="tab" value="<%= activeTab %>">
              <button type="button"
                      class="public-filter-toggle"
                      data-dropdown-id="public-category-dropdown"
                      aria-expanded="false">
                <span><%= guestCategoryLabel %></span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6.8 9.5 5.2 5.2 5.2-5.2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>

              <div class="public-filter-list" data-dropdown-panel="public-category-dropdown" hidden>
                <% [{ value: "general", label: "General" }, { value: "videos", label: "Videos" }, { value: "posts", label: "Posts" }].forEach(option => { %>
                  <button type="submit"
                          name="category"
                          value="<%= option.value %>"
                          class="public-filter-option <%= activeCategory === option.value ? 'is-active is-warm' : '' %>">
                    <span><%= option.label %></span>
                    <% if (activeCategory === option.value) { %>
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4 4L19 6.8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <% } %>
                  </button>
                <% }) %>
              </div>
            </form>

            <section class="public-side-card public-login-card">
              <div class="public-login-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 11.3a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Zm0 2.6c-4.3 0-7.5 2.3-8.3 5.8a1 1 0 0 0 1 1.3h14.6a1 1 0 0 0 1-1.3c-.8-3.5-4-5.8-8.3-5.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
              </div>
              <h3>Login</h3>
              <p>Login to like, comment and save posts with your own profile.</p>
              <a href="/login" class="public-primary-btn text-decoration-none">Go to login</a>
            </section>
          </aside>
        </div>
      </section>
    </section>
  </main>

  <script>
    function closePublicMenus() {
      document.querySelectorAll(".public-menu-card").forEach((menu) => {
        menu.hidden = true;
      });
    }

    function closePublicDropdowns() {
      document.querySelectorAll("[data-dropdown-panel]").forEach((panel) => {
        panel.hidden = true;
      });

      document.querySelectorAll(".public-filter-toggle").forEach((button) => {
        button.setAttribute("aria-expanded", "false");
      });
    }

    function sharePublicPost(url, text) {
      const finalUrl = url.startsWith("http") ? url : window.location.origin + url;

      if (navigator.share) {
        navigator.share({
          title: "Delulu",
          text,
          url: finalUrl
        }).catch(() => {});
        return;
      }

      if (navigator.clipboard) {
        navigator.clipboard.writeText(finalUrl)
          .then(() => alert("Link copied to clipboard"))
          .catch(() => {
            window.open("https://wa.me/?text=" + encodeURIComponent(text + " " + finalUrl), "_blank");
          });
        return;
      }

      window.open("https://wa.me/?text=" + encodeURIComponent(text + " " + finalUrl), "_blank");
    }

    document.addEventListener("click", function (event) {
      const menuToggle = event.target.closest(".public-menu-toggle");
      if (menuToggle) {
        const menu = document.querySelector(`[data-menu-for='${menuToggle.dataset.menuId}']`);
        const shouldOpen = menu.hidden;
        closePublicMenus();
        menu.hidden = !shouldOpen;
        return;
      }

      const dropdownToggle = event.target.closest(".public-filter-toggle");
      if (dropdownToggle) {
        const panel = document.querySelector(`[data-dropdown-panel='${dropdownToggle.dataset.dropdownId}']`);
        const shouldOpen = panel.hidden;
        closePublicDropdowns();
        panel.hidden = !shouldOpen;
        dropdownToggle.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
        return;
      }

      if (!event.target.closest(".public-menu-wrap")) {
        closePublicMenus();
      }

      if (!event.target.closest(".public-filter-card")) {
        closePublicDropdowns();
      }
    });

    document.querySelectorAll(".public-share-btn").forEach((button) => {
      button.addEventListener("click", function () {
        sharePublicPost(button.dataset.shareUrl || "/", button.dataset.shareText || "Check out Delulu");
      });
    });

    document.querySelectorAll(".public-report-trigger").forEach((button) => {
      button.addEventListener("click", async function () {
        const postId = button.dataset.postId;
        const reason = window.prompt("Why are you reporting this post?", "Reported from public feed");

        if (!postId || reason === null) {
          return;
        }

        const response = await fetch(`/report/${postId}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({ reason })
        });

        const result = await response.json().catch(() => ({ error: "Unable to submit report" }));

        if (!response.ok) {
          alert(result.error || "Unable to submit report");
          return;
        }

        closePublicMenus();
        alert("Report submitted");
      });
    });
  </script>
</body>
</html>
