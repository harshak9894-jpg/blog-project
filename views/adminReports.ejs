<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Reports</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body">
<main class="page-wrap page-stack">
  <% if (success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (error.length > 0) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <section class="hero-card">
    <span class="eyebrow">Backend Reports</span>
    <h1 class="mt-3 mb-2">Report Queue</h1>
    <p class="section-subtitle mb-0">Only <strong><%= adminEmail %></strong> can access this page.</p>
  </section>

  <% if (reports.length === 0) { %>
    <div class="empty-state">No reports have been submitted yet.</div>
  <% } %>

  <% reports.forEach(report => { %>
    <article class="feed-card">
      <div class="author-row mb-3">
        <div>
          <h3 class="mb-1"><%= report.postTitle %></h3>
          <p class="meta-text mb-0">
            by <strong><%= report.postAuthorName %></strong>
            <% if (report.postAuthorHandle) { %>
              (@<%= report.postAuthorHandle %>)
            <% } %>
          </p>
        </div>
        <span class="badge-soft <%= report.status === 'resolved' ? '' : 'warm' %>"><%= report.status %></span>
      </div>

      <div class="meta-row mb-3">
        <span class="tag-chip">Reporter: <%= report.reporterName || "Guest" %></span>
        <% if (report.reporterEmail) { %>
          <span class="tag-chip"><%= report.reporterEmail %></span>
        <% } %>
        <span class="tag-chip"><%= new Date(report.createdAt).toLocaleString("en-IN") %></span>
      </div>

      <p class="mb-3"><%= report.reason %></p>

      <div class="action-row">
        <% if (report.postUrl) { %>
          <a href="<%= report.postUrl %>" class="btn btn-ghost text-decoration-none">Open Post</a>
        <% } %>

        <% if (report.status !== "resolved") { %>
          <form action="/admin/reports/<%= report._id %>/resolve" method="POST">
            <button type="submit" class="btn btn-brand">Mark Resolved</button>
          </form>
        <% } %>
      </div>
    </article>
  <% }) %>
</main>
</body>
</html>
