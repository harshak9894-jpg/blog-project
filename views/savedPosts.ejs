<!DOCTYPE html>
<html>
<head>
  <title>Saved Posts</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body <%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<main class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'page-wrap' %>">
  <% if (success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (error.length > 0) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <% if (savedPosts.length === 0) { %>
    <div class="empty-state">You have not saved any posts yet.</div>
  <% } %>

  <% savedPosts.forEach(post => { %>
    <article class="content-card mb-4">
      <div>
        <div class="meta-row mb-2">
          <span class="badge-soft"><%= post.category || "general" %></span>
          <span class="badge-soft warm"><%= post.visibility || "public" %></span>
        </div>
        <h3 class="mb-2"><%= post.title %></h3>
        <p class="mb-2"><%= post.content.length > 180 ? post.content.slice(0, 180) + "..." : post.content %></p>
        <p class="meta-text mb-0">By <%= post.author.displayName || post.author.username %></p>
      </div>
    </article>
  <% }) %>
</main>

</body>
</html>
