<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body auth-page">
<main class="auth-screen">
  <section class="auth-stage auth-stage-login">
    <div class="auth-panel">
      <div class="auth-visual" aria-hidden="true"></div>

      <div class="auth-form-card">
      <% if (success.length > 0) { %>
        <div class="alert alert-success auth-alert"><%= success %></div>
      <% } %>

      <% if (error.length > 0) { %>
        <div class="alert alert-danger auth-alert"><%= error %></div>
      <% } %>

        <div class="auth-brand-lockup">
          <img src="/delulu-logo.png" alt="Delulu logo" class="auth-card-logo">
          <span class="auth-brand-name">DELULU</span>
        </div>

        <div class="auth-form-head">
          <h1>Login</h1>
          <p>Use your email and password to continue.</p>
        </div>

        <form action="/login" method="POST" class="auth-form-stack">
          <div class="auth-input-group">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control auth-input" placeholder="username@gmail.com" required>
          </div>

          <div class="auth-input-group">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control auth-input" placeholder="Password" required>
          </div>

          <button type="submit" class="btn auth-submit-btn w-100">Sign In</button>
        </form>

        <a href="/register" class="auth-switch-link">Register new account</a>
      </div>
    </div>
  </section>
</main>
</body>
</html>
