<!DOCTYPE html>
<html>
<head>
  <title>Page Not Found | Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="<%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<div class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'container mt-5' %>">
  <div class="alert alert-warning">
    <h2 class="h4 mb-2">Page not found</h2>
    <p class="mb-0">The page you requested does not exist.</p>
  </div>

  <a href="/" class="btn btn-dark">Back to Home</a>
</div>

</body>
</html>
