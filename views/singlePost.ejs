<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= post.title %> | Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body <%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<main class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'page-wrap' %> page-stack">
  <% if (success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (error.length > 0) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <section class="page-header-card">
    <span class="eyebrow">Post</span>
    <h1 class="display-title"><%= post.title %></h1>
    <p class="section-subtitle">Read the full post, review its stats, and share or download the media.</p>
  </section>

  <section class="detail-grid">
    <aside class="content-card sticky-card">
      <span class="eyebrow">Post Overview</span>
      <div class="stats-band">
        <div class="stat-tile">
          <strong><%= post.likes.length %></strong>
          Likes
        </div>
        <div class="stat-tile">
          <strong><%= post.comments.length %></strong>
          Comments
        </div>
        <div class="stat-tile">
          <strong><%= post.visibility || "public" %></strong>
          Audience
        </div>
      </div>

      <div class="divider-line"></div>

      <div class="action-row">
        <button onclick="shareCurrent()" class="btn btn-brand">Share</button>
        <% if (post.media) { %>
          <a href="<%= post.media %>" download class="btn btn-ghost text-decoration-none">Download Media</a>
        <% } %>
      </div>
    </aside>

    <article class="content-card">
      <div class="meta-row mb-3">
        <span class="badge-soft"><%= post.category || "general" %></span>
        <span class="badge-soft warm"><%= post.visibility || "public" %></span>
      </div>

      <h1 class="display-title mb-3"><%= post.title %></h1>
      <p class="mb-3"><%= post.content %></p>

      <% if (post.author) { %>
        <p class="meta-text mb-3">Posted by <%= post.author.displayName || post.author.username %> (@<%= post.author.handle || post.author.username %>)</p>
      <% } %>

      <% if (post.tags && post.tags.length > 0) { %>
        <div class="meta-row mb-3">
          <% post.tags.forEach(tag => { %>
            <span class="tag-chip">#<%= tag %></span>
          <% }) %>
        </div>
      <% } %>

      <% if (post.media) { %>
        <% if (post.mediaType === "image") { %>
          <img src="<%= post.media %>" alt="Post media" class="post-media image mb-3">
        <% } else { %>
          <video controls autoplay muted loop playsinline class="post-media video mb-3">
            <source src="<%= post.media %>">
          </video>
        <% } %>
      <% } %>

      <p class="meta-text mb-0"><%= post.likes.length %> Likes | <%= post.comments.length %> Comments</p>
    </article>
  </section>
</main>

<script>
function shareCurrent() {
  const url = window.location.href;
  const text = "Check this post on Delulu: " + url;

  if (navigator.share) {
    navigator.share({
      title: document.title,
      text: text,
      url: url
    });
  } else {
    const whatsappUrl = "https://wa.me/?text=" + encodeURIComponent(text);
    window.open(whatsappUrl, "_blank");
  }
}
</script>

</body>
</html>
