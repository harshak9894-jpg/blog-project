<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Register</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body">
<%- include("partials/navbar") %>

<main class="page-wrap page-stack">
  <section class="auth-layout">
    <div class="auth-card">
      <% if (success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <% if (error.length > 0) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="content-card-header">
        <span class="eyebrow">Start Here</span>
        <h1 class="content-card-title">Register</h1>
        <p class="content-card-subtitle">Create your account and choose how your profile will appear to others.</p>
      </div>

      <form action="/register" method="POST">
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Handle</label>
          <input type="text" name="handle" class="form-control" placeholder="yourname">
          <div class="form-text">Optional. We can generate one from your username.</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" required>
        </div>

        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" required>
        </div>

        <button type="submit" class="btn btn-brand w-100">Create Account</button>
      </form>

      <p class="small-note mt-4 mb-0">Already have an account? <a href="/login">Login here</a></p>
    </div>
  </section>
</main>
</body>
</html>
