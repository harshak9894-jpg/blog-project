<!DOCTYPE html>
<html>
<head>
  <title>Edit Post</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body <%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<main class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'page-wrap' %>">
  <% if (success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (error.length > 0) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <section class="hero-card mb-4">
    <span class="eyebrow">Edit Content</span>
    <h1 class="display-title mt-3 mb-2">Refine your post.</h1>
    <p class="hero-subtitle mb-0">Update the message, discovery tags, and audience settings without losing the original post thread.</p>
  </section>

  <section class="content-card">
    <form action="/edit/<%= post._id %>?_method=PUT" method="POST">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" name="title" value="<%= post.title %>" class="form-control" required>
      </div>

      <div class="mb-4">
        <label class="form-label">Content</label>
        <textarea name="content" class="form-control" rows="6" required><%= post.content %></textarea>
      </div>

      <div class="row">
        <div class="col-lg-4 mb-3">
          <label class="form-label">Category</label>
          <select name="category" class="form-select">
            <option value="general" <%= post.category === "general" ? "selected" : "" %>>General</option>
            <option value="photo" <%= post.category === "photo" ? "selected" : "" %>>Photo</option>
            <option value="video" <%= post.category === "video" ? "selected" : "" %>>Video</option>
            <option value="discussion" <%= post.category === "discussion" ? "selected" : "" %>>Discussion</option>
          </select>
        </div>

        <div class="col-lg-4 mb-3">
          <label class="form-label">Visibility</label>
          <select name="visibility" class="form-select">
            <option value="public" <%= post.visibility === "public" ? "selected" : "" %>>Public</option>
            <option value="followers" <%= post.visibility === "followers" ? "selected" : "" %>>Followers Only</option>
          </select>
        </div>

        <div class="col-lg-4 mb-3">
          <label class="form-label">Tags</label>
          <input type="text" name="tags" value="<%= (post.tags || []).join(', ') %>" class="form-control">
        </div>
      </div>

      <div class="action-row">
        <button class="btn btn-brand" type="submit">Update Post</button>
        <a href="/profile/<%= user %>" class="btn btn-ghost text-decoration-none">Cancel</a>
      </div>
    </form>
  </section>
</main>

</body>
</html>
