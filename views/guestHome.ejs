<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body guest-home-body">
  <main class="guest-home-shell">
    <header class="guest-home-navbar">
      <div class="guest-home-brand">
        <a href="/" class="guest-home-brand-link" aria-label="Delulu Home">
          <img src="/delulu-logo.png" alt="Delulu logo" class="guest-home-brand-mark">
          <span class="guest-home-brand-word">DELULU</span>
        </a>
      </div>

      <nav class="guest-home-nav">
        <a href="/" class="guest-home-nav-link is-active">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.2 3.8 10v10.2h5.4v-6.4h5.6v6.4h5.4V10L12 3.2Z" fill="currentColor"/></svg>
          <span>HOME</span>
        </a>
      </nav>

      <a href="/login" class="guest-home-login-btn">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 11.4a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Zm0 2.4c-4 0-7.2 2.3-8.1 5.8a1 1 0 0 0 1 1.2h14.2a1 1 0 0 0 1-1.2c-.9-3.5-4.1-5.8-8.1-5.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
        <span>Login</span>
      </a>
    </header>

    <section class="guest-home-frame">
      <% if (success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <% if (error.length > 0) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="guest-home-grid">
        <div class="guest-feed-column">
          <article class="guest-card guest-compose-card">
            <div class="guest-author-row">
              <img src="/uploads/profile/default-avatar.svg" alt="Default profile" class="guest-avatar-image guest-avatar-lg">
              <div class="guest-author-copy">
                <strong>@account_name</strong>
              </div>
            </div>

            <a href="/login" class="guest-compose-box text-decoration-none">Post something...</a>

            <div class="guest-compose-actions">
              <div class="guest-action-metrics">
                <a href="/login" class="guest-action-chip heart text-decoration-none">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20.3s-6.7-4.2-9.2-8.4C.8 8.5 2.3 4.7 6 4.4c2.1-.2 3.4.8 4.4 2.2 1-1.4 2.3-2.4 4.4-2.2 3.7.3 5.2 4.1 3.2 7.5-2.5 4.2-9.2 8.4-9.2 8.4Z" fill="currentColor"/></svg>
                  <span>Like</span>
                </a>
                <a href="/login" class="guest-action-chip text-decoration-none">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 11.5c0 4.7-4.1 8.5-9.1 8.5-1.2 0-2.4-.2-3.5-.7L3 20.7l1.4-3.5A8 8 0 0 1 1.8 11.5C1.8 6.8 5.9 3 10.9 3s9.1 3.8 9.1 8.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                  <span>Comment</span>
                </a>
                <button type="button" class="guest-action-chip guest-share-btn" data-share-url="/" data-share-text="See what people are posting on Delulu">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 9.7 14.3m11.3-11.3-7.5 18-3.8-7L2 10.2 21 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>Share</span>
                </button>
              </div>

              <div class="guest-divider"></div>

              <div class="guest-action-links">
                <a href="/login" class="guest-action-link text-decoration-none">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v11m0 0 4.1-4.1M12 14.5l-4.1-4.1M4 18.7h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>Download</span>
                </a>
                <a href="/login" class="guest-action-link save text-decoration-none">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3.7h12a1 1 0 0 1 1 1v15.6l-7-3.8-7 3.8V4.7a1 1 0 0 1 1-1Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                  <span>Save</span>
                </a>
                <button type="button" class="guest-more-btn guest-menu-toggle" data-menu-id="guest-compose-menu" aria-label="More options">...</button>
              </div>
            </div>

            <div class="guest-card-menu" data-menu-for="guest-compose-menu" hidden>
              <button type="button" class="guest-card-menu-item guest-report-trigger" data-post-id="" data-post-title="General guest feed">Report</button>
            </div>
          </article>

          <% if (posts.length === 0) { %>
            <article class="guest-card guest-feed-card">
              <div class="guest-text-copy">
                <p>No public posts yet. Once you log in and create one, it will show up here.</p>
              </div>
            </article>
          <% } %>

          <% posts.forEach(post => { %>
            <article class="guest-card guest-feed-card <%= post.media ? 'has-media' : '' %>">
              <div class="guest-card-top">
                <div class="guest-author-row compact">
                  <img src="<%= post.author.profilePic || '/uploads/profile/default-avatar.svg' %>"
                       alt="Profile picture"
                       class="guest-avatar-image guest-avatar-md">
                  <div class="guest-author-copy">
                    <strong>@<%= post.author.handle || post.author.username %></strong>
                    <span><%= post.relativeTime %></span>
                  </div>
                </div>

                <div class="guest-post-tools">
                  <button type="button"
                          class="guest-dots-btn guest-menu-toggle"
                          data-menu-id="post-menu-<%= post._id %>"
                          aria-label="More actions">...</button>
                  <div class="guest-card-menu" data-menu-for="post-menu-<%= post._id %>" hidden>
                    <button type="button"
                            class="guest-card-menu-item guest-report-trigger"
                            data-post-id="<%= post._id %>"
                            data-post-title="<%= post.title %>">
                      Report
                    </button>
                  </div>
                </div>
              </div>

              <% if (post.media) { %>
                <div class="guest-media-row">
                  <% if (post.mediaType === "image") { %>
                    <img src="<%= post.media %>" alt="Post media" class="guest-inline-media">
                  <% } else { %>
                    <video class="guest-inline-media" muted playsinline controls>
                      <source src="<%= post.media %>" type="video/mp4">
                    </video>
                  <% } %>
                  <div class="guest-media-copy">
                    <h3><%= post.title %></h3>
                    <p><%= post.content %></p>
                  </div>
                </div>
              <% } else { %>
                <div class="guest-text-copy">
                  <h3 class="guest-post-title"><%= post.title %></h3>
                  <p><%= post.content %></p>
                </div>
              <% } %>

              <div class="guest-post-actions">
                <a href="/login" class="guest-inline-stat heart text-decoration-none" title="Login to like">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20.3s-6.7-4.2-9.2-8.4C.8 8.5 2.3 4.7 6 4.4c2.1-.2 3.4.8 4.4 2.2 1-1.4 2.3-2.4 4.4-2.2 3.7.3 5.2 4.1 3.2 7.5-2.5 4.2-9.2 8.4-9.2 8.4Z" fill="currentColor"/></svg>
                  <span><%= post.likes.length %></span>
                </a>
                <a href="/post/<%= post._id %>#comments" class="guest-inline-stat text-decoration-none" title="View comments">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 11.5c0 4.7-4.1 8.5-9.1 8.5-1.2 0-2.4-.2-3.5-.7L3 20.7l1.4-3.5A8 8 0 0 1 1.8 11.5C1.8 6.8 5.9 3 10.9 3s9.1 3.8 9.1 8.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                  <span><%= post.comments.length %></span>
                </a>
                <button type="button"
                        class="guest-inline-stat guest-share-btn"
                        data-share-url="/post/<%= post._id %>"
                        data-share-text="<%= post.title %>">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 3 9.7 14.3m11.3-11.3-7.5 18-3.8-7L2 10.2 21 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span><%= Math.max(post.comments.length + post.likes.length, 1) %></span>
                </button>
                <div class="guest-divider"></div>
                <% if (post.media) { %>
                  <a href="<%= post.media %>" download class="guest-action-link text-decoration-none">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v11m0 0 4.1-4.1M12 14.5l-4.1-4.1M4 18.7h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>Download</span>
                  </a>
                <% } else { %>
                  <a href="/post/<%= post._id %>" class="guest-action-link text-decoration-none">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5v11m0 0 4.1-4.1M12 14.5l-4.1-4.1M4 18.7h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>Open</span>
                  </a>
                <% } %>
                <a href="/login" class="guest-action-link save text-decoration-none" title="Login to save">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3.7h12a1 1 0 0 1 1 1v15.6l-7-3.8-7 3.8V4.7a1 1 0 0 1 1-1Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                  <span>Save</span>
                </a>
              </div>
            </article>
          <% }) %>
        </div>

        <aside class="guest-side-column">
          <form action="/" method="GET" class="guest-side-card guest-filter-form" id="guest-sort-form">
            <input type="hidden" name="category" value="<%= activeCategory %>">
            <div class="guest-side-head">
              <button type="button" class="guest-dropdown-toggle" data-dropdown-id="guest-sort-dropdown">
                <span><%= guestTabLabel %></span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6.7 9.2 5.3 5.3 5.3-5.3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
            <div class="guest-select-list blue" data-dropdown-panel="guest-sort-dropdown">
              <% [{ value: "latest", label: "Latest" }, { value: "old", label: "Old" }, { value: "popular", label: "Popular" }].forEach(option => { %>
                <button type="submit"
                        name="tab"
                        value="<%= option.value %>"
                        class="guest-select-item <%= activeTab === option.value ? 'is-active' : '' %>">
                  <span><%= option.label %></span>
                  <% if (activeTab === option.value) { %>
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.3 4.1 4.1L19 6.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% } %>
                </button>
              <% }) %>
            </div>
          </form>

          <form action="/" method="GET" class="guest-side-card warm guest-filter-form" id="guest-category-form">
            <input type="hidden" name="tab" value="<%= activeTab %>">
            <div class="guest-side-head">
              <button type="button" class="guest-dropdown-toggle warm" data-dropdown-id="guest-category-dropdown">
                <span><%= guestCategoryLabel %></span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6.7 9.2 5.3 5.3 5.3-5.3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
            <div class="guest-select-list warm" data-dropdown-panel="guest-category-dropdown">
              <% [{ value: "general", label: "General" }, { value: "videos", label: "Videos" }, { value: "posts", label: "Posts" }].forEach(option => { %>
                <button type="submit"
                        name="category"
                        value="<%= option.value %>"
                        class="guest-select-item <%= activeCategory === option.value ? 'is-active' : '' %>">
                  <span><%= option.label %></span>
                  <% if (activeCategory === option.value) { %>
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.3 4.1 4.1L19 6.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% } %>
                </button>
              <% }) %>
            </div>
          </form>

          <section class="guest-side-card guest-login-card">
            <div class="guest-login-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 11.4a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Zm0 2.4c-4 0-7.2 2.3-8.1 5.8a1 1 0 0 0 1 1.2h14.2a1 1 0 0 0 1-1.2c-.9-3.5-4.1-5.8-8.1-5.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            </div>
            <h3>Login</h3>
            <p>Login to like, comment and save posts with your own profile.</p>
            <a href="/login" class="guest-side-login-link">Go to login</a>
          </section>
        </aside>
      </div>
    </section>
  </main>

  <script>
    function closeGuestMenus() {
      document.querySelectorAll(".guest-card-menu").forEach((menu) => {
        menu.hidden = true;
      });
    }

    function shareGuestPost(url, text) {
      const finalUrl = url.startsWith("http") ? url : window.location.origin + url;

      if (navigator.share) {
        navigator.share({
          title: "Delulu",
          text,
          url: finalUrl
        }).catch(() => {});
        return;
      }

      if (navigator.clipboard) {
        navigator.clipboard.writeText(finalUrl)
          .then(() => alert("Link copied to clipboard"))
          .catch(() => window.open("https://wa.me/?text=" + encodeURIComponent(text + " " + finalUrl), "_blank"));
        return;
      }

      window.open("https://wa.me/?text=" + encodeURIComponent(text + " " + finalUrl), "_blank");
    }

    document.addEventListener("click", function (event) {
      const menuToggle = event.target.closest(".guest-menu-toggle");
      if (menuToggle) {
        const menuId = menuToggle.dataset.menuId;
        const menu = document.querySelector(`[data-menu-for='${menuId}']`);
        const isHidden = menu.hidden;
        closeGuestMenus();
        menu.hidden = !isHidden;
        return;
      }

      if (!event.target.closest(".guest-card-menu")) {
        closeGuestMenus();
      }
    });

    document.querySelectorAll(".guest-share-btn").forEach((button) => {
      button.addEventListener("click", function () {
        shareGuestPost(button.dataset.shareUrl || "/", button.dataset.shareText || "Check out this post on Delulu");
      });
    });

    document.querySelectorAll(".guest-report-trigger").forEach((button) => {
      button.addEventListener("click", async function () {
        const postId = button.dataset.postId;

        if (!postId) {
          alert("Please login to create and manage posts.");
          return;
        }

        const reason = window.prompt("Why are you reporting this post?", "Reported from public feed");
        if (reason === null) {
          return;
        }

        const response = await fetch(`/report/${postId}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({ reason })
        });

        const result = await response.json().catch(() => ({ error: "Unable to submit report" }));

        if (!response.ok) {
          alert(result.error || "Unable to submit report");
          return;
        }

        closeGuestMenus();
        alert("Report submitted");
      });
    });

    document.querySelectorAll(".guest-dropdown-toggle").forEach((button) => {
      button.addEventListener("click", function () {
        const panel = document.querySelector(`[data-dropdown-panel='${button.dataset.dropdownId}']`);
        panel.classList.toggle("is-collapsed");
      });
    });
  </script>
</body>
</html>
