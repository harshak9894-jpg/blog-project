<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= profileUser.displayName || profileUser.username %> | Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body <%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<main class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'page-wrap' %>">
  <% if (success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (error.length > 0) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <section class="profile-hero-card mb-4">
    <div class="profile-hero-main">
      <img src="<%= profileUser.profilePic %>?v=<%= Date.now() %>"
           alt="Profile picture"
           class="avatar-lg">

      <div class="profile-identity">
        <span class="eyebrow">Profile</span>
        <h1 class="mt-3 mb-1"><%= profileUser.displayName || profileUser.username %></h1>
        <p class="handle-text mb-2">@<%= profileUser.handle || profileUser.username %></p>
        <p class="profile-bio-text mb-0"><%= profileUser.bio || "No bio added yet." %></p>
        <% const msgPrivacy = profileUser.allowMessages === "everyone"
          ? "Open to everyone"
          : profileUser.allowMessages === "followers"
            ? "Only followers can start chats"
            : "Closed to new chats"; %>
        <p class="meta-text mt-3 mb-0">Messages: <%= msgPrivacy %></p>
      </div>
    </div>

    <div class="profile-hero-side">
      <% if (user && user.toString() === profileUser._id.toString()) { %>
        <div class="profile-header-actions">
          <div class="profile-page-menu-wrap">
            <button type="button"
                    class="profile-page-menu-btn"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="Profile options">&#8942;</button>
            <div class="profile-page-menu-panel" role="menu">
              <a href="/edit-profile" class="profile-page-menu-item text-decoration-none" role="menuitem">Edit profile</a>
              <a href="/saved" class="profile-page-menu-item text-decoration-none" role="menuitem">Saved posts</a>
              <a href="/settings" class="profile-page-menu-item text-decoration-none" role="menuitem">Settings</a>
              <a href="/logout" class="profile-page-menu-item danger text-decoration-none" role="menuitem">Log out</a>
            </div>
          </div>
        </div>
      <% } %>

      <div class="stats-band profile-stats-band">
        <div class="stat-tile">
          <strong><%= profileUser.followers.length %></strong>
          Followers
        </div>
        <div class="stat-tile">
          <strong><%= profileUser.following.length %></strong>
          Following
        </div>
        <div class="stat-tile">
          <strong><%= profilePosts.length %></strong>
          Posts
        </div>
      </div>

      <% if (user && user.toString() === profileUser._id.toString()) { %>
        <div class="action-row mt-3">
          <a href="/edit-profile" class="btn btn-accent text-decoration-none">Edit profile</a>
        </div>
      <% } %>

      <% if (user && user.toString() !== profileUser._id.toString()) { %>
        <div class="action-row mt-3">
          <button type="button" class="btn btn-brand w-100 follow-btn" data-id="<%= profileUser._id %>">
            <%= isFollowing ? "Unfollow" : "Follow" %>
          </button>
          <% if (canMessage) { %>
            <a href="/inbox/start/<%= profileUser._id %>" class="btn btn-ghost w-100 text-decoration-none">Message</a>
          <% } else { %>
            <button type="button" class="btn btn-ghost w-100" disabled>Messages Closed</button>
          <% } %>
        </div>
        <% if (!canMessage) { %>
          <p class="meta-text mt-2 mb-0">This user is not accepting new chats right now.</p>
        <% } %>
      <% } %>
    </div>
  </section>

  <% if (profilePosts.length === 0) { %>
    <div class="empty-state">No posts available yet.</div>
  <% } %>

  <% profilePosts.forEach(post => { %>
    <% const likeCount = (post.likes && post.likes.length) || 0; %>
    <% const commentCount = (post.comments && post.comments.length) || 0; %>
    <% const isOwner = user && String(user) === String(profileUser._id); %>
    <article class="content-card mb-4 profile-post-card">
      <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
        <div class="meta-row mb-0">
          <span class="badge-soft"><%= post.category || "general" %></span>
          <span class="badge-soft warm"><%= post.visibility || "public" %></span>
        </div>
        <% if (isOwner) { %>
          <div class="profile-post-menu-wrap">
            <button type="button"
                    class="profile-post-menu-btn"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="Post options">&#8942;</button>
            <div class="profile-post-menu-panel" role="menu">
              <a href="/edit/<%= post._id %>" class="profile-post-menu-item text-decoration-none" role="menuitem">Edit</a>
              <form action="/delete/<%= post._id %>?_method=DELETE"
                    method="POST"
                    class="profile-post-menu-delete-form"
                    role="none"
                    onsubmit="return confirm('Delete this post?');">
                <button type="submit" class="profile-post-menu-item danger" role="menuitem">Delete</button>
              </form>
            </div>
          </div>
        <% } %>
      </div>

      <h3 class="mb-2"><%= post.title %></h3>
      <p class="mb-3"><%= post.content.length > 180 ? post.content.slice(0, 180) + "..." : post.content %></p>

      <% if (post.media) { %>
        <% if (post.mediaType === "image") { %>
          <a href="/post/<%= post._id %>" class="d-inline-block mb-3">
            <img src="<%= post.media %>" alt="" class="post-media image profile-post-thumb">
          </a>
        <% } else if (post.mediaType === "video") { %>
          <div class="mb-3">
            <video controls preload="metadata" playsinline class="post-media video profile-post-thumb">
              <source src="<%= post.media %>" type="video/mp4">
            </video>
          </div>
        <% } else { %>
          <a href="/post/<%= post._id %>" class="btn btn-soft btn-sm mb-3 text-decoration-none">View media</a>
        <% } %>
      <% } %>

      <% if (post.tags && post.tags.length > 0) { %>
        <div class="meta-row mb-3">
          <% post.tags.forEach(tag => { %>
            <span class="tag-chip">#<%= tag %></span>
          <% }) %>
        </div>
      <% } %>

      <p class="meta-text mb-0"><%= likeCount %> likes | <%= commentCount %> comments</p>
    </article>
  <% }) %>
</main>

<script>
document.querySelectorAll(".follow-btn").forEach(function (button) {
  button.addEventListener("click", async function () {
    const userId = this.dataset.id;
    const res = await fetch("/follow/" + userId, { method: "POST" });
    const data = await res.json();

    if (!res.ok) {
      alert(data.error || "Unable to update follow status");
      return;
    }

    this.textContent = data.following ? "Unfollow" : "Follow";
  });
});

(function () {
  document.querySelectorAll(".profile-page-menu-btn").forEach(function (btn) {
    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();
      var wrap = btn.closest(".profile-page-menu-wrap");
      var panel = wrap && wrap.querySelector(".profile-page-menu-panel");
      if (!panel) return;
      var wasOpen = panel.classList.contains("is-open");
      document.querySelectorAll(".profile-page-menu-panel").forEach(function (p) {
        p.classList.remove("is-open");
      });
      document.querySelectorAll(".profile-page-menu-btn").forEach(function (b) {
        b.setAttribute("aria-expanded", "false");
      });
      if (!wasOpen) {
        panel.classList.add("is-open");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });

  document.querySelectorAll(".profile-post-menu-btn").forEach(function (btn) {
    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();
      var wrap = btn.closest(".profile-post-menu-wrap");
      var panel = wrap && wrap.querySelector(".profile-post-menu-panel");
      if (!panel) return;
      var wasOpen = panel.classList.contains("is-open");
      document.querySelectorAll(".profile-post-menu-panel").forEach(function (p) {
        p.classList.remove("is-open");
      });
      document.querySelectorAll(".profile-post-menu-btn").forEach(function (b) {
        b.setAttribute("aria-expanded", "false");
      });
      if (!wasOpen) {
        panel.classList.add("is-open");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });

  document.addEventListener("click", function () {
    document.querySelectorAll(".profile-page-menu-panel.is-open").forEach(function (p) {
      p.classList.remove("is-open");
    });
    document.querySelectorAll(".profile-page-menu-btn").forEach(function (b) {
      b.setAttribute("aria-expanded", "false");
    });
    document.querySelectorAll(".profile-post-menu-panel.is-open").forEach(function (p) {
      p.classList.remove("is-open");
    });
    document.querySelectorAll(".profile-post-menu-btn").forEach(function (b) {
      b.setAttribute("aria-expanded", "false");
    });
  });
})();
</script>

</body>
</html>
