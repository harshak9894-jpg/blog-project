<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Error | Delulu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="<%= user ? 'sidebar-expanded' : '' %>">

<% if (user) { %>
  <%- include("partials/sidebar") %>
<% } else { %>
  <%- include("partials/navbar") %>
<% } %>

<div class="<%= user ? 'page-wrap page-wrap-with-sidebar' : 'container mt-5' %>">
  <div class="alert alert-danger">
    <h2 class="h4 mb-2">Something went wrong</h2>
    <p class="mb-2"><%= message %></p>
    <p class="mb-0 text-muted">Status code: <%= statusCode %></p>
  </div>

  <a href="/" class="btn btn-primary">Go Home</a>
</div>

</body>
</html>
