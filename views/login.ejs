<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body class="app-body">
<%- include("partials/navbar") %>

<main class="page-wrap page-stack">
  <section class="auth-layout">
    <div class="auth-card">
      <% if (success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <% if (error.length > 0) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="content-card-header">
        <span class="eyebrow">Account Access</span>
        <h1 class="content-card-title">Login</h1>
        <p class="content-card-subtitle">Use your email and password to continue.</p>
      </div>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>

        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
        </div>

        <button type="submit" class="btn btn-brand w-100">Login</button>
      </form>

      <p class="small-note mt-4 mb-0">Need an account? <a href="/register">Create one here</a></p>
    </div>
  </section>
</main>
</body>
</html>
